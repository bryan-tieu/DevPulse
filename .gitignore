.venv/
__pycache__/
*.pyc
.env
*.json
.terraform/
*.tfstate
*.tfstate.*
terraform/tfplan
*.tfvars
!*.tfvars.example
*.gz
test.py

airflow/logs

# Spark local scratch (created when Spark runs with a local warehouse/metastore)
spark-warehouse/
metastore_db/
derby.log

# dbt: generated artifacts + host/user connection config
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/profiles.yml
dbt/.user.yml
# warm-up drill scratch files (progress log is docs/warmups.md, committed)
warmups/

# great expectations: scratch/results stay out; declarative suite JSON goes IN
# (the un-ignore is needed because *.json is globally ignored above — without
# it the expectation suites would silently never be tracked)
quality/gx/uncommitted/
!quality/gx/**/*.json
quality/run_summary.json